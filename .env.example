# === App Factory / AutoLauncher ===

# Database (Railway PostgreSQL)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# AI
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-...

# Auth
JWT_SECRET=change-me-32-chars-minimum

# First user (created on startup)
SEED_EMAIL=your@email.com
SEED_PASSWORD=YourSecurePassword!

# CORS
ALLOWED_ORIGINS=https://your-dashboard.vercel.app,http://localhost:5173

# Optional
DEVIN_API_KEY=
SENTRY_DSN=
