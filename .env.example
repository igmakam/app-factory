# App Factory — Environment Variables

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/appfactory

# Temporal
TEMPORAL_HOST=localhost:7233

# AI
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...

# Telegram (bot token + your chat ID for alerts)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Security
JWT_SECRET=change-me-in-production
ALLOWED_ORIGINS=http://localhost:3000,https://your-dashboard.com

# Monitoring
SENTRY_DSN=

# Workers
IOS_WORKER_URL=http://mac-mini-local:8001
ANDROID_WORKER_URL=http://vps-android:8002
